  "scope_lock": {
    "source": "Build macOS menu bar app (Swift+SwiftUI, MenuBarExtra) that tracks AI quota from 2 providers (MiniMax /v1/token_plan/remains + Hapo Hub <HAPO_HOST>) and edits Claude Code global config (~/.claude/settings.json). Personal use, no code signing.",
    "in_scope": [
      "Native macOS menu bar app shell (MenuBarExtra) with popover UI",
      "QuotaProvider protocol with 2 built-in adapters: MiniMaxProvider, HapoHubProvider",
      "QuotaService: 60s polling, cache, parallel fetch, error isolation",
      "ConfigService: read/write global ~/.claude/settings.json with 3-deep ring .bak backup",
      "Settings sheet: per-provider token entry, enable/disable toggle, persists to providers.json with atomic write",
      "Keychain storage for provider tokens AND env.ANTHROPIC_API_KEY (no plaintext on disk; settings.json uses KEYCHAIN_REF placeholder for ANTHROPIC_API_KEY)",
      "API key masking in UI (fe_oa_\u2022\u2022\u2022\u20224a8)",
      "Post-save banner reminding user to restart Claude Code",
      "xcodebuild produces a runnable .app"
    ],
    "out_of_scope": [
      "Code signing / notarization / distribution",
      "Multi-user accounts",
      "Auto-update mechanism",
      "Editing Claude Code hooks (view-only in MVP)",
      "Per-project ~/.claude/projects/<id>/ settings.json editing (v2 \u2014 see decision register)",
      "Generic JSON-field editor (use typed form fields only)",
      "Additional providers beyond MiniMax and Hapo Hub (extend later via protocol)"
    ],
    "expansion_policy": "requires-user-approval"
  },
